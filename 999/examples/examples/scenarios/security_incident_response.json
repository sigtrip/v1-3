{
  "name": "security_incident_response",
  "description": "Реакция на инцидент безопасности: снимок, диагностика, уведомление, откат.",
  "trigger": {
    "type": "event",
    "source": "system.alert",
    "match": {
      "severity": ["high", "critical"],
      "category": ["security", "integrity"]
    }
  },
  "steps": [
    {
      "id": "snapshot_before_action",
      "action": "create_snapshot",
      "params": {
        "label": "incident_pre_action"
      }
    },
    {
      "id": "collect_diagnostics",
      "action": "health_check",
      "params": {
        "include": ["modules", "database", "configs", "imports"]
      }
    },
    {
      "id": "isolate_node",
      "action": "network_isolation",
      "params": {
        "mode": "restrict_outbound"
      }
    },
    {
      "id": "notify_admin",
      "action": "send_telegram_alert",
      "params": {
        "severity": "critical",
        "template": "security_incident"
      }
    }
  ],
  "rollback": {
    "enabled": true,
    "strategy": "latest_stable_snapshot"
  }
}
